# MCPanel environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# A long random string used to sign login tokens.
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-string

# Panel login username
PANEL_USERNAME=admin

# Bcrypt hash of your password. Leave empty to use the default "admin" password.
# Generate with: docker exec mcpanel node -e "console.log(require('bcryptjs').hashSync('yourpassword', 12))"
# Or locally:    npm run hash yourpassword
#
# ⚠️  IMPORTANT: Docker Compose treats $ as a variable reference in .env files.
# You MUST escape every $ in the hash by doubling it to $$.
#
# Example — if the hash command outputs:
#   $2a$12$QBFm5pfhCG9xud.Fe/OBx.cO5yGtumLf
#
# Then write it in .env as:
#   PANEL_PASSWORD_HASH=$$2a$$12$$QBFm5pfhCG9xud.Fe/OBx.cO5yGtumLf
#
# MCPanel will automatically un-escape $$ back to $ when reading the value.
PANEL_PASSWORD_HASH=
