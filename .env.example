# MCPanel environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# A long random string used to sign login tokens.
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-string

# Panel login username
PANEL_USERNAME=admin

# Bcrypt hash of your password. Leave empty to use the default "admin" password.
# Generate with: docker exec mcpanel node -e "console.log(require('bcryptjs').hashSync('yourpassword', 12))"
# Or locally:    npm run hash yourpassword
PANEL_PASSWORD_HASH=
